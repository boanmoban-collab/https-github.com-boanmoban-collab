# Maria Bot Environment Configuration Example

# Node.js environment mode (production / development)
NODE_ENV=development

# (Optional) Server-side Gemini API key if required for intelligence features
GEMINI_API_KEY=

# MEXC API Access Credentials (Real Trading)
MEXC_API_KEY=your_mexc_public_api_key_here
MEXC_API_SECRET=your_mexc_private_secret_key_here
